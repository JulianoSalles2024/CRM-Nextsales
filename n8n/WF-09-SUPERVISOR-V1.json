    {
      "parameters": {
        "jsCode": "const insightsData = $('Code - Parse Insights').first().json;\nconst adminRaw = $input.first().json;\nconst adminArr = Array.isArray(adminRaw) ? adminRaw : [adminRaw];\nconst admin = adminArr[0];\n\nif (!admin || !admin.id) return [];\n\nconst criticalCount = insightsData.insights.filter(i => i.severity === 'critical').length;\nconst total = insightsData.insights.length;\n\nconst title = criticalCount > 0\n  ? `⚠️ Supervisor: ${criticalCount} alerta(s) crítico(s)`\n  : `🧠 Supervisor: ${total} novo(s) insight(s)`;\n\nreturn [{\n  json: {\n    company_id: insightsData.company_id,\n    recipient_user_id: admin.id,\n    type: 'lead_assigned',\n    title: title,\n    body: `Análise diária dos agentes e vendedores está disponível na Central de Comando.`,\n    is_read: false\n  }\n}];"
      },
