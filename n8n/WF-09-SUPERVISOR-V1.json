      "id": "wf09-node-011",
      "name": "HTTP - Get Leads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2400, 120]
    },
    {
      "parameters": {
        "jsCode": "// ── Helpers ────────────────────────────────────────────────\nconst company = $('Loop - Companies').first().json;\n\n// Credenciais OpenAI\nconst credRaw = $('HTTP - Get OpenAI Credentials').first().json;\nconst credArr = Array.isArray(credRaw) ? credRaw : [credRaw];\nconst openAiKey = credArr[0]?.ai_api_key ?? null;\n\n// Agentes\nconst agentsRaw = $('HTTP - Get Agents Info').first().json;\nconst agents = Array.isArray(agentsRaw) ? agentsRaw : (agentsRaw?.id ? [agentsRaw] : []);\n\n// Performance dos agentes (últimos 7 dias)\nconst perfRaw = $('HTTP - Get Agent Performance').first().json;\nconst perfRows = Array.isArray(perfRaw) ? perfRaw : (perfRaw?.agent_id ? [perfRaw] : []);\n\n// Agregar performance por agente\nconst perfMap = {};\nfor (const row of perfRows) {\n  if (!row.agent_id) continue;\n  if (!perfMap[row.agent_id]) {\n    perfMap[row.agent_id] = { approaches: 0, responses: 0, qualified: 0, meetings: 0, sales: 0, revenue: 0, escalations: 0 };\n  }\n  const m = perfMap[row.agent_id];\n  m.approaches  += row.approaches  || 0;\n  m.responses   += row.responses   || 0;\n  m.qualified   += row.qualified   || 0;\n  m.meetings    += row.meetings    || 0;\n  m.sales       += row.sales       || 0;\n  m.revenue     += row.revenue     || 0;\n  m.escalations += row.escalations || 0;\n}\n\n// Montar resumo dos agentes\nconst agentsSummary = agents.map(a => {\n  const p = perfMap[a.id] || { approaches: 0, responses: 0, qualified: 0, meetings: 0, sales: 0, revenue: 0 };\n  const responseRate = p.approaches > 0 ? ((p.responses / p.approaches) * 100).toFixed(1) : '0';\n  const convRate = p.responses > 0 ? ((p.sales / p.responses) * 100).toFixed(1) : '0';\n  return {\n    id: a.id,\n    name: a.name,\n    type: a.function_type,\n    active: a.is_active,\n    monthly_goal: a.monthly_goal,\n    goal_metric: a.goal_metric,\n    last_7_days: {\n      approaches: p.approaches,\n      responses: p.responses,\n      qualified: p.qualified,\n      meetings: p.meetings,\n      sales: p.sales,\n      revenue: p.revenue,\n      response_rate_pct: parseFloat(responseRate),\n      conversion_rate_pct: parseFloat(convRate)\n    }\n  };\n});\n\n// Vendedores\nconst sellersRaw = $('HTTP - Get Sellers').first().json;\nconst sellers = Array.isArray(sellersRaw) ? sellersRaw : (sellersRaw?.id ? [sellersRaw] : []);\n\n// Leads\nconst leadsRaw = $('HTTP - Get Leads').first().json;\nconst leads = Array.isArray(leadsRaw) ? leadsRaw : (leadsRaw?.id ? [leadsRaw] : []);\n\nconst now = Date.now();\nconst day7 = 7 * 24 * 60 * 60 * 1000;\nconst day30 = 30 * 24 * 60 * 60 * 1000;\nconst day5 = 5 * 24 * 60 * 60 * 1000;\n\n// Agregar leads por vendedor\nconst sellerMap = {};\nfor (const s of sellers) {\n  sellerMap[s.id] = { total: 0, won_30d: 0, lost_30d: 0, stale: 0, revenue_30d: 0, last_activity: null };\n}\n\nfor (const lead of leads) {\n  if (!lead.owner_id || !sellerMap[lead.owner_id]) continue;\n  const m = sellerMap[lead.owner_id];\n  m.total++;\n\n  const updatedAt = new Date(lead.updated_at).getTime();\n  const wonAt = lead.won_at ? new Date(lead.won_at).getTime() : null;\n  const lostAt = lead.lost_at ? new Date(lead.lost_at).getTime() : null;\n\n  if (wonAt && (now - wonAt) < day30) {\n    m.won_30d++;\n    m.revenue_30d += parseFloat(lead.value || 0);\n  }\n  if (lostAt && (now - lostAt) < day30) m.lost_30d++;\n  if ((now - updatedAt) > day5 && lead.status !== 'GANHO' && lead.status !== 'PERDIDO') m.stale++;\n  if (!m.last_activity || updatedAt > new Date(m.last_activity).getTime()) m.last_activity = lead.updated_at;\n}\n\nconst sellersSummary = sellers.map(s => {\n  const m = sellerMap[s.id] || {};\n  const daysSinceLast = m.last_activity ? Math.floor((now - new Date(m.last_activity).getTime()) / (24*60*60*1000)) : 99;\n  return {\n    id: s.id,\n    name: s.name,\n    leads_total: m.total || 0,\n    leads_won_30d: m.won_30d || 0,\n    leads_lost_30d: m.lost_30d || 0,\n    leads_stale: m.stale || 0,\n    revenue_30d: m.revenue_30d || 0,\n    days_since_last_activity: daysSinceLast\n  };\n});\n\n// System prompt\nconst systemPrompt = `Você é um Supervisor Comercial de IA da plataforma NextSales.\nSua função é analisar dados de performance de agentes de IA e vendedores humanos e gerar insights acionáveis para o gestor.\n\nRegras obrigatórias:\n- Retorne APENAS um JSON válido com a chave \"insights\" contendo um array\n- Máximo de 6 insights no total\n- Cada insight deve ter: agent_id (uuid ou null), profile_id (uuid ou null), type, severity, content, recommendation\n- type deve ser um de: performance_drop, script_issue, channel_weak, goal_risk, general\n- severity deve ser um de: critical, warning, info\n- critical: métrica abaixo de 30% do esperado ou situação urgente\n- warning: métrica entre 30-70% do esperado ou situação preocupante\n- info: observação positiva ou neutra\n- content: descrição clara do problema/situação em português (máx 120 chars)\n- recommendation: ação específica que o gestor deve tomar (máx 100 chars)\n- Foque nos problemas mais importantes, não repita insights similares\n- Se não há problemas, gere insights positivos (info)`;\n\n// User message com dados\nconst userData = JSON.stringify({\n  empresa: company.name,\n  data_analise: new Date().toISOString().split('T')[0],\n  agentes: agentsSummary,\n  vendedores: sellersSummary\n}, null, 2);\n\nreturn [{\n  json: {\n    company_id: company.id,\n    company_name: company.name,\n    openai_key: openAiKey,\n    agents: agentsSummary,\n    sellers: sellersSummary,\n    system_prompt: systemPrompt,\n    user_message: userData\n  }\n}];"
      },
      "id": "wf09-node-012",
      "name": "Code - Aggregate & Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 120]
    },
    {
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"model\": \"gpt-4o-mini\", \"response_format\": { \"type\": \"json_object\" }, \"max_tokens\": 1200, \"messages\": [ { \"role\": \"system\", \"content\": \"{{ $json.system_prompt }}\" }, { \"role\": \"user\", \"content\": \"{{ $json.user_message }}\" } ] }",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.openai_key }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "options": {
          "timeout": 30000,
          "response": { "response": { "neverError": true } }
        }
      },
      "id": "wf09-node-013",
      "name": "HTTP - OpenAI Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2880, 120]
    },
    {
      "parameters": {
        "jsCode": "const aggregated = $('Code - Aggregate & Build Prompt').first().json;\nconst openaiRaw = $input.first().json;\n\n// Extrair conteúdo da resposta OpenAI\nlet parsed;\ntry {\n  const content = openaiRaw?.choices?.[0]?.message?.content;\n  if (!content) return [];\n  parsed = JSON.parse(content);\n} catch(e) {\n  return [];\n}\n\nconst insights = Array.isArray(parsed.insights) ? parsed.insights : [];\nif (insights.length === 0) return [];\n\n// Validar e preparar para inserção\nconst validTypes = ['performance_drop','script_issue','channel_weak','goal_risk','general'];\nconst validSeverities = ['info','warning','critical'];\n\nconst rows = [];\nfor (const ins of insights) {\n  if (!ins.content) continue;\n  if (!validTypes.includes(ins.type)) ins.type = 'general';\n  if (!validSeverities.includes(ins.severity)) ins.severity = 'info';\n  rows.push({\n    company_id: aggregated.company_id,\n    agent_id: ins.agent_id || null,\n    profile_id: ins.profile_id || null,\n    type: ins.type,\n    severity: ins.severity,\n    content: String(ins.content).slice(0, 300),\n    recommendation: ins.recommendation ? String(ins.recommendation).slice(0, 200) : null,\n    is_read: false,\n    is_applied: false\n  });\n}\n\nif (rows.length === 0) return [];\n\nreturn [{ json: { company_id: aggregated.company_id, insights: rows } }];"
      },
      "id": "wf09-node-014",
      "name": "Code - Parse Insights",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3120, 120]
    },
    {
