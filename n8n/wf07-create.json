ok_id }}"},{"name":"select","value":"*"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"apikey","value":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZoa2hhbXdyZnd0YWN3eWR1a3ZiIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2NTMyNjcxMywiZXhwIjoyMDgwOTAyNzEzfQ.slNbow0lzBpryTaPPNNPDOV5x_uBqRHQZR38RRk92sY"},{"name":"Authorization","value":"Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZoa2hhbXdyZnd0YWN3eWR1a3ZiIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2NTMyNjcxMywiZXhwIjoyMDgwOTAyNzEzfQ.slNbow0lzBpryTaPPNNPDOV5x_uBqRHQZR38RRk92sY"},{"name":"Content-Type","value":"application/json"}]},"options":{}},"id":"a1b2c3d4-e5f6-7890-abcd-ef1234560006","name":"HTTP - Get Playbook","type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1120,300],"continueOnFail":true,"alwaysOutputData":true},{"parameters":{"url":"https://fhkhamwrfwtacwydukvb.supabase.co/rest/v1/messages","sendQuery":true,"queryParameters":{"parameters":[{"name":"conversation_id","value":"=eq.{{ $('Webhook').item.json.body.conversation_id }}"},{"name":"select","value":"direction,content,content_type,created_at"},{"name":"order","value":"created_at.desc"},{"name":"limit","value":"10"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"apikey","value":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZoa2hhbXdyZnd0YWN3eWR1a3ZiIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2NTMyNjcxMywiZXhwIjoyMDgwOTAyNzEzfQ.slNbow0lzBpryTaPPNNPDOV5x_uBqRHQZR38RRk92sY"},{"name":"Authorization","value":"Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZoa2hhbXdyZnd0YWN3eWR1a3ZiIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2NTMyNjcxMywiZXhwIjoyMDgwOTAyNzEzfQ.slNbow0lzBpryTaPPNNPDOV5x_uBqRHQZR38RRk92sY"},{"name":"Content-Type","value":"application/json"}]},"options":{}},"id":"a1b2c3d4-e5f6-7890-abcd-ef1234560007","name":"HTTP - Get Messages","type":"n8n-nodes-base.httpRequest","typeVersion":4.2,"position":[1400,300],"alwaysOutputData":true,"continueOnFail":true},{"parameters":{"jsCode":"const webhookData = $('Webhook').item.json.body;\nconst agentRaw = $('HTTP - Get Agent').item.json;\nconst agent = Array.isArray(agentRaw) ? agentRaw[0] : agentRaw;\nconst leadRaw = $('HTTP - Get Lead').item.json;\nconst lead = Array.isArray(leadRaw) ? leadRaw[0] : leadRaw;\n\n// Memory (may be empty for new leads)\nlet memory = null;\ntry {\n  const memData = $('HTTP - Get Memory').item.json;\n  memory = Array.isArray(memData) ? memData[0] : memData;\n  if (!memory || !memory.id) memory = null;\n} catch(e) {}\n\n// Playbook (may be empty)\nlet playbook = null;\ntry {\n  const pbData = $('HTTP - Get Playbook').item.json;\n  playbook = Array.isArray(pbData) ? pbData[0] : pbData;\n  if (!playbook || !playbook.id) playbook = null;\n} catch(e) {}\n\n// Messages history\nlet messages = [];\ntry {\n  messages = $('HTTP - Get Messages').all().map(m => m.json);\n} catch(e) {}\n\n// Build history (reverse to chronological)\nconst history = messages.reverse().map(m => {\n  const role = m.direction === 'inbound' ? (lead.name || 'Lead') : 'VocГЄ';\n  return `${role}: ${m.content || ''}`;\n}).join('\\n') || 'Nenhuma mensagem anterior.';\n\n// Memory context\nconst memCtx = memory ? `\nMEMГ“RIA COMERCIAL:\n- EstГЎgio atual: ${memory.stage || 'new'}\n- NГ­vel de interesse: ${memory.interest_level || 'nГЈo avaliado'}\n- OrГ§amento detectado: ${memory.budget_detected ? 'R$ ' + memory.budget_detected : 'nГЈo informado'}\n- Decisor: ${memory.decision_maker === true ? 'sim' : memory.decision_maker === false ? 'nГЈo' : 'nГЈo identificado'}\n- ObjeГ§Гµes levantadas: ${(memory.detected_objections || []).join(', ') || 'nenhuma'}\n- NВє de abordagens: ${memory.approach_count || 0}\n- NВє de respostas: ${memory.response_count || 0}\n- Гљltima aГ§ГЈo: ${memory.last_action || 'nenhuma'}\n- Notas: ${memory.notes || 'nenhuma'}\n` : '(Lead novo вЂ” primeira interaГ§ГЈo deste agente)';\n\n// Playbook context\nconst pbCtx = playbook ? `\nPLAYBOOK:\nScripts de abertura: ${(playbook.opening_scripts || []).join(' | ') || 'nГЈo definido'}\nObjeГ§Гµes e respostas:\n${Object.entries(playbook.objection_map || {}).map(([k,v]) => `- \"${k}\" в†’ \"${v}\"`).join('\\n') || 'nГЈo definido'}\nPerguntas de qualificaГ§ГЈo:\n${(playbook.qualification_questions || []).map(q => `- ${q.question}`).join('\\n') || 'nГЈo definido'}\n` : '';\n\n// Escalate rules\nconst escalate = agent.escalate_rules || {};\n\n// Replace variables in opening_script\nlet systemPrompt = agent.opening_script || `VocГЄ Г© um agente comercial da empresa. Tom: ${agent.tone || 'consultivo'}.`;\nsystemPrompt = systemPrompt\n  .replace(/\\{company_name\\}/g, 'NextSales')\n  .replace(/\\{\\{tone\\}\\}/g, agent.tone || 'consultivo')\n  .replace(/\\{\\{niche\\}\\}/g, agent.niche || 'geral')\n  .replace(/\\{\\{client_type\\}\\}/g, agent.client_type || 'medium')\n  .replace(/\\{\\{qualification_questions\\}\\}/g, (playbook?.qualification_questions || []).map(q => `- ${q.question}`).join('\\n') || 'a definir')\n  .replace(/\\{\\{objection_map\\}\\}/g, Object.entries(playbook?.objection_map || {}).map(([k,v]) => `- \"${k}\": \"${v}\"`).join('\\n') || 'a definir')\n  .replace(/\\{\\{max_followups\\}\\}/g, String(escalate.max_followups || 5))\n  .replace(/\\{\\{min_ticket\\}\\}/g, escalate.min_ticket_to_escalate ? `R$ ${escalate.min_ticket_to_escalate}` : 'nГЈo definido');\n\n// Full prompt\nconst fullPrompt = `${systemPrompt}\n\nв”Ѓв”Ѓв”Ѓ CONTEXTO DO LEAD в”Ѓв”Ѓв”Ѓ\nNome: ${lead.name || 'nГЈo informado'}\nEmpresa: ${lead.company || 'nГЈo informada'}\nTelefone: ${lead.phone || ''}\n\nв”Ѓв”Ѓв”Ѓ ${memCtx}\n\nв”Ѓв”Ѓв”Ѓ HISTГ“RICO DA CONVERSA в”Ѓв”Ѓв”Ѓ\n${history}\n${pbCtx}\nв”Ѓв”Ѓв”Ѓ REGRAS DE ESCALAГ‡ГѓO в”Ѓв”Ѓв”Ѓ\n- MГЎx. follow-ups sem resposta: ${escalate.max_followups || 5}\n- Escalar se interesse muito alto: ${escalate.escalate_on_high_interest ? 'SIM' : 'NГѓO'}\n- Keywords para escalar: ${(escalate.keywords || []).join(', ') || 'nenhuma'}\n\nв”Ѓв”Ѓв”Ѓ FERRAMENTAS DISPONГЌVEIS в”Ѓв”Ѓв”Ѓ\nUse as tools para registrar decisГµes comerciais:\n- atualizar_memoria: registre estГЎgio, interesse, objeГ§Гµes, notas apГіs cada interaГ§ГЈo\n- agendar_followup: quando o lead precisar ser contactado novamente\n- escalar_para_humano: quando detectar interesse muito alto, pedido de contrato ou keyword de escalaГ§ГЈo\n\nResponda APENAS com a mensagem natural para o lead. NГЈo use aspas nem prefixos.`;\n\nconst userMessage = webhookData.input_text ||\n  (webhookData.content_type === 'proactive' ? 'INSTRUГ‡ГѓO INTERNA: Inicie uma abordagem proativa com este lead.' :\n   webhookData.content_type === 'followup' ? 'INSTRUГ‡ГѓO INTERNA: Execute o follow-up agendado com este lead.' :\n   'OlГЎ');\n\nreturn { systemPrompt: fullPrompt, userMessage, webhookData };"},"id":"a1b2c3d4-e5f6-7890-abcd-ef1234560008","name":"Code - Build Prompt","type":"n8n-nodes-base.code","typeVersion":2,"position":[1680,300]},{"parameters":{"promptType":"define","text":"={{ .first().json.userMessage }}","options":{"systemMessage":"={{ .first().json.systemPrompt }}","maxIterations":5}},"id":"a1b2c3d4-e5f6-7890-abcd-ef1234560009","name":"AI Agent","type":"@n8n/n8n-nodes-langchain.agent","typeVersion":1.7,"position":[1960,300]},{"parameters":{"model":"gpt-4o-mini","options":{"maxTokens":800,"temperature":0.7}},"id":"a1b2c3d4-e5f6-7890-abcd-ef1234560010","name":"OpenAI Chat Model","type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","typeVersion":1.1,"position":[1760,520],"credentials":{"openAiApi":{"id":"openai-credentials","name":"OpenAI API"}}},{"parameters":{"name":"atualizar_memoria","description":"Registra e atualiza a memГіria comercial do lead: estГЎgio atual, nГ­vel de interesse, objeГ§Гµes detectadas, notas da conversa. Use sempre apГіs uma interaГ§ГЈo importante.","method":"POST","url":"https://fhkhamwrfwtacwydukvb.supabase.co/rest/v1/rpc/upsert_agent_lead_memory","sendHeaders":true,"headerParameters":{"parameters":[{"name":"apikey","v