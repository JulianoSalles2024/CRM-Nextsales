    {
      "parameters": {
        "jsCode": "// ── Node 3: Validate Payload ──────────────────────────────────────────────\n// Accepts Evolution API webhook payload, filters out non-message events,\n// fromMe=true, group messages, and missing required fields.\n\nconst body = ($input.first().json.body !== undefined)\n  ? $input.first().json.body\n  : $input.first().json;\n\nconst eventType = (body.event || body.type || '').toLowerCase();\nconst validPrefixes = ['messages.upsert', 'message_received', 'message'];\nconst isValidEvent = validPrefixes.some(function(p) { return eventType.includes(p); });\n\nif (!isValidEvent) {\n  return [{ json: { valid: false, reason: 'not_message_event', event_type: eventType } }];\n}\n\nconst data  = body.data || body;\nconst key   = data.key || (data.message && data.message.key) || {};\nconst msg   = data.message || data;\n\nif (key.fromMe === true) {\n  return [{ json: { valid: false, reason: 'from_me' } }];\n}\n\nconst remoteJid         = key.remoteJid  || '';\nconst instanceName      = body.instance  || body.instanceName || '';\nconst externalMessageId = key.id         || '';\n\nif (!remoteJid || !instanceName || !externalMessageId) {\n  return [{ json: { valid: false, reason: 'missing_required_fields' } }];\n}\n\n// Skip group messages — remove this block if you want to handle groups\nif (remoteJid.endsWith('@g.us')) {\n  return [{ json: { valid: false, reason: 'group_message_skipped' } }];\n}\n\nconst contactIdentifier = remoteJid.replace(/@.*$/, '');\n\nlet contentType = 'text';\nlet contentText = null;\nlet mediaUrl    = null;\nlet caption     = null;\n\nif (msg.conversation) {\n  contentText = msg.conversation;\n} else if (msg.extendedTextMessage && msg.extendedTextMessage.text) {\n  contentText = msg.extendedTextMessage.text;\n} else if (msg.imageMessage) {\n  contentType = 'image';\n  mediaUrl    = msg.imageMessage.url     || null;\n  caption     = msg.imageMessage.caption || null;\n} else if (msg.audioMessage) {\n  contentType = 'audio';\n  mediaUrl    = msg.audioMessage.url || null;\n} else if (msg.documentMessage) {\n  contentType = 'document';\n  mediaUrl    = msg.documentMessage.url   || null;\n  caption     = msg.documentMessage.title || null;\n} else if (msg.videoMessage) {\n  contentType = 'video';\n  mediaUrl    = msg.videoMessage.url     || null;\n  caption     = msg.videoMessage.caption || null;\n} else {\n  contentType = 'unknown';\n}\n\nconst contactName = data.pushName || data.notifyName || null;\nconst ts          = data.messageTimestamp;\nconst sentAt      = ts ? new Date(Number(ts) * 1000).toISOString() : new Date().toISOString();\n\nreturn [{\n  json: {\n    valid:                true,\n    instance_name:        instanceName,\n    external_message_id:  externalMessageId,\n    contact_identifier:   contactIdentifier,\n    contact_name:         contactName,\n    contact_jid:          remoteJid,\n    content_type:         contentType,\n    content_text:         contentText,\n    media_url:            mediaUrl,\n    caption:              caption,\n    sent_at:              sentAt,\n    raw_body:             body\n  }\n}];"
      },
