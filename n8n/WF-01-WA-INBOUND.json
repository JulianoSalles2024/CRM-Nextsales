    {
      "parameters": {
        "jsCode": "// ── Node 8: Normalize to Canonical Event ─────────────────────────────────\n// Merges validated payload + connection data into the canonical event JSON.\n// Optionally validates HMAC signature if EVOLUTION_WEBHOOK_SECRET is set.\n\nconst validated = $('Code - Validate Payload').first().json;\nconst conn      = $input.first().json;\n\n// ── Optional HMAC validation ─────────────────────────────────────────────\nconst secret = '';\nif (secret) {\n  let headers = {};\n  try { headers = $('Webhook Trigger').first().json.headers || {}; } catch(e) {}\n  const sig = headers['x-evolution-signature'] || headers['x-hub-signature-256'] || '';\n  if (!sig) {\n    throw new Error('HMAC secret configured but no signature header received');\n  }\n  const crypto   = require('crypto');\n  const rawBody  = JSON.stringify(validated.raw_body);\n  const expected = 'sha256=' + crypto.createHmac('sha256', secret).update(rawBody).digest('hex');\n  if (sig !== expected) {\n    throw new Error('Invalid webhook signature — possible spoofed request');\n  }\n}\n\nconst canonicalEvent = {\n  event_id:              validated.external_message_id + '_' + conn.company_id,\n  source:                'evolution_api',\n  channel:               'whatsapp',\n  instance_name:         validated.instance_name,\n  channel_connection_id: conn.id,\n  company_id:            conn.company_id,\n  direction:             'inbound',\n  external_message_id:   validated.external_message_id,\n  contact_identifier:    validated.contact_identifier,\n  contact_name:          validated.contact_name,\n  contact_jid:           validated.contact_jid,\n  content_type:          validated.content_type,\n  content_text:          validated.content_text,\n  media_url:             validated.media_url,\n  caption:               validated.caption,\n  sent_at:               validated.sent_at,\n  raw_payload:           validated.raw_body\n};\n\nreturn [{ json: canonicalEvent }];"
      },
