    {
      "parameters": {
        "jsCode": "// ── Node 6: Extract Connection ───────────────────────────────────────────\n// PostgREST returns an array. Extract the first row or flag as not found.\n\nconst items = $input.all();\nlet connection = null;\n\nfor (var i = 0; i < items.length; i++) {\n  var item = items[i].json;\n  if (Array.isArray(item) && item.length > 0) {\n    connection = item[0];\n    break;\n  } else if (item && item.id) {\n    connection = item;\n    break;\n  }\n}\n\nif (!connection || !connection.id || !connection.company_id) {\n  return [{ json: { found: false } }];\n}\n\nreturn [{\n  json: {\n    found:      true,\n    id:         connection.id,\n    company_id: connection.company_id,\n    channel:    connection.channel,\n    external_id: connection.external_id\n  }\n}];"
      },
      "id": "f1a07b30-8471-4096-9758-ee320a551b3c",
