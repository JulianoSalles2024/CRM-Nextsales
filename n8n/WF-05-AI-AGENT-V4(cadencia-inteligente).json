            "id": "a1b2c3d4-0014-4000-8000-000000000014",
            "name": "HTTP - Insert Agent Message",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [3360, 300],
            "continueOnFail": true
        },

        {
            "parameters": {
                "jsCode": "// ── Cadência Inteligente: detecta gatilhos configurados no estágio ──\n//\n// auto_triggers pode conter strings simples ou objetos { keyword: '...' }\n// Suporta ambos os formatos para compatibilidade.\n\nconst webhook      = $('Webhook Trigger').first().json.body;\nconst content_text = (webhook.content_text || '').toLowerCase();\n\nconst stageData       = $('HTTP - Get Stage').first().json;\nconst auto_triggers   = Array.isArray(stageData.auto_triggers) ? stageData.auto_triggers : [];\nconst requires_approval = stageData.requires_approval ?? false;\nconst auto_playbook_id  = stageData.auto_playbook_id  ?? null;\n\nconst leadData         = $('HTTP - Get Lead').first().json;\nconst convData         = $('HTTP - Get Conversation').first().json;\nconst current_column_id = leadData.column_id;\nconst lead_id           = convData.lead_id;\nconst company_id        = webhook.company_id;\n\n// Verifica se algum gatilho bate com o texto recebido\nlet matched_trigger = null;\nfor (const trigger of auto_triggers) {\n  const keyword = (typeof trigger === 'object'\n    ? (trigger.keyword || '')\n    : (trigger || '')\n  ).toLowerCase().trim();\n  if (keyword && content_text.includes(keyword)) {\n    matched_trigger = keyword;\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    trigger_detected:   !!matched_trigger,\n    matched_trigger,\n    requires_approval,\n    auto_playbook_id,\n    current_column_id,\n    lead_id,\n    lead_name:   leadData.name  || '',\n    company_id,\n  }\n}];"
            },
            "id": "a1b2c3d4-0015-4000-8000-000000000015",
            "name": "Code - Check Triggers",
            "type": "n8n-nodes-base.code",
