                "jsonBody": "={\n  \"p_company_id\":          \"{{ $('Webhook Trigger').first().json.body.company_id }}\",\n  \"p_conversation_id\":     \"{{ $('Webhook Trigger').first().json.body.conversation_id }}\",\n  \"p_external_message_id\": \"agent-{{ Date.now() }}\",\n  \"p_direction\":           \"outbound\",\n  \"p_sender_type\":         \"agent\",\n  \"p_content\":             \"{{ $('HTTP - Call OpenAI').first().json.choices[0].message.content }}\",\n  \"p_content_type\":        \"text\",\n  \"p_sent_at\":             \"{{ new Date().toISOString() }}\",\n  \"p_media_url\":           null,\n  \"p_metadata\":            {}\n}",
                "options": {}
