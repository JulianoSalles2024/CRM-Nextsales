            "id": "a1b2c3d4-0017-4000-8000-000000000017",
            "name": "HTTP - Get Next Stage",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [3080, 600],
            "continueOnFail": true
        },
        {
