    {
      "parameters": {
        "jsCode": "// Calculate token estimates, cost, duration and generate LangSmith run ID\nconst agentOutput = $('AI Agent').first().json.output || '';\nconst startData = $('Code - Capture Start').first().json;\nconst startTime = startData._start_time;\nconst promptCharLength = startData._prompt_char_length || 0;\n\nconst endTime = new Date().toISOString();\nconst durationMs = startTime ? Math.round(new Date(endTime) - new Date(startTime)) : 0;\n\n// Token estimation: ~4 chars per token (GPT-4o-mini)\nconst tokensInput = Math.ceil(promptCharLength / 4);\nconst tokensOutput = Math.ceil(agentOutput.length / 4);\n\n// GPT-4o-mini pricing: $0.15/1M input, $0.60/1M output\nconst costUsd = parseFloat(\n  ((tokensInput * 0.00000015) + (tokensOutput * 0.00000060)).toFixed(6)\n);\n\n// Generate UUID v4 for LangSmith run ID\nconst langsmithRunId = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n  const r = Math.random() * 16 | 0;\n  return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n});\n\nreturn [{\n  json: {\n    ...$('AI Agent').first().json,\n    _tokens_input: tokensInput,\n    _tokens_output: tokensOutput,\n    _cost_usd: costUsd,\n    _duration_ms: durationMs,\n    _langsmith_run_id: langsmithRunId,\n    _start_time: startTime,\n    _end_time: endTime,\n    _prompt_char_length: promptCharLength,\n  }\n}];"
      },
