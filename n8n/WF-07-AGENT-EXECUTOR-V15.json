    {
      "parameters": {
        "jsCode": "const webhookData = $('Webhook').item.json.body;\nconst agentRaw = $('HTTP - Get Agent').item.json;\nconst agent = Array.isArray(agentRaw) ? agentRaw[0] : agentRaw;\nconst leadRaw = $('HTTP - Get Lead').item.json;\nconst lead = Array.isArray(leadRaw) ? leadRaw[0] : leadRaw;\n\n// Memory (may be empty for new leads)\nlet memory = null;\ntry {\n  const memData = $('HTTP - Get Memory').item.json;\n  memory = Array.isArray(memData) ? memData[0] : memData;\n  if (!memory || !memory.id) memory = null;\n} catch(e) {}\n\n// Playbook (may be empty)\nlet playbook = null;\ntry {\n  const pbData = $('HTTP - Get Playbook').item.json;\n  playbook = Array.isArray(pbData) ? pbData[0] : pbData;\n  if (!playbook || !playbook.id) playbook = null;\n} catch(e) {}\n\n// Messages history\nlet messages = [];\ntry {\n  messages = $('HTTP - Get Messages').all().map(m => m.json);\n} catch(e) {}\n\n// Build history (reverse to chronological)\nconst history = messages.reverse().map(m => {\n  const role = m.direction === 'inbound' ? (lead.name || 'Lead') : 'Você';\n  return `${role}: ${m.content || ''}`;\n}).join('\\n') || 'Nenhuma mensagem anterior.';\n\n// Memory context\nconst memCtx = memory ? `\nMEMÓRIA COMERCIAL:\n- Estágio atual: ${memory.stage || 'new'}\n- Nível de interesse: ${memory.interest_level || 'não avaliado'}\n- Orçamento detectado: ${memory.budget_detected ? 'R$ ' + memory.budget_detected : 'não informado'}\n- Decisor: ${memory.decision_maker === true ? 'sim' : memory.decision_maker === false ? 'não' : 'não identificado'}\n- Objeções levantadas: ${(memory.detected_objections || []).join(', ') || 'nenhuma'}\n- Nº de abordagens: ${memory.approach_count || 0}\n- Nº de respostas: ${memory.response_count || 0}\n- Última ação: ${memory.last_action || 'nenhuma'}\n- Notas: ${memory.notes || 'nenhuma'}\n` : '(Lead novo — primeira interação deste agente)';\n\n// Playbook context\nconst pbCtx = playbook ? `\nPLAYBOOK:\nScripts de abertura: ${(playbook.opening_scripts || []).join(' | ') || 'não definido'}\nObjeções e respostas:\n${Object.entries(playbook.objection_map || {}).map(([k,v]) => `- \"${k}\" → \"${v}\"`).join('\\n') || 'não definido'}\nPerguntas de qualificação:\n${(playbook.qualification_questions || []).map(q => `- ${q.question}`).join('\\n') || 'não definido'}\n` : '';\n\n// Escalate rules\nconst escalate = agent.escalate_rules || {};\n\n// Replace variables in opening_script\nlet systemPrompt = agent.opening_script || `Você é um agente comercial da empresa. Tom: ${agent.tone || 'consultivo'}.`;\nsystemPrompt = systemPrompt\n  .replace(/\\{company_name\\}/g, 'NextSales')\n  .replace(/\\{\\{tone\\}\\}/g, agent.tone || 'consultivo')\n  .replace(/\\{\\{niche\\}\\}/g, agent.niche || 'geral')\n  .replace(/\\{\\{client_type\\}\\}/g, agent.client_type || 'medium')\n  .replace(/\\{\\{qualification_questions\\}\\}/g, (playbook?.qualification_questions || []).map(q => `- ${q.question}`).join('\\n') || 'a definir')\n  .replace(/\\{\\{objection_map\\}\\}/g, Object.entries(playbook?.objection_map || {}).map(([k,v]) => `- \"${k}\": \"${v}\"`).join('\\n') || 'a definir')\n  .replace(/\\{\\{max_followups\\}\\}/g, String(escalate.max_followups || 5))\n  .replace(/\\{\\{min_ticket\\}\\}/g, escalate.min_ticket_to_escalate ? `R$ ${escalate.min_ticket_to_escalate}` : 'não definido');\n\n// Full prompt\nconst fullPrompt = `${systemPrompt}\n\n━━━ CONTEXTO DO LEAD ━━━\nNome: ${lead.name || 'não informado'}\nEmpresa: ${lead.company || 'não informada'}\nTelefone: ${lead.phone || ''}\n\n━━━ ${memCtx}\n\n━━━ HISTÓRICO DA CONVERSA ━━━\n${history}\n${pbCtx}\n━━━ REGRAS DE ESCALAÇÃO ━━━\n- Máx. follow-ups sem resposta: ${escalate.max_followups || 5}\n- Escalar se interesse muito alto: ${escalate.escalate_on_high_interest ? 'SIM' : 'NÃO'}\n- Keywords para escalar: ${(escalate.keywords || []).join(', ') || 'nenhuma'}\n\n━━━ FERRAMENTAS DISPONÍVEIS ━━━\nVocê pode usar as tools abaixo para registrar decisões comerciais. Use com CRITÉRIO:\n\n- atualizar_memoria: use SOMENTE quando o lead revelar informação relevante (objeção, budget, prazo, cargo, nível de interesse claro). NÃO use em primeiras trocas genéricas.\n- agendar_followup: use quando o lead pedir para falar depois ou quando você decidir retomar em horário específico.\n- escalar_para_humano: use SOMENTE quando ocorrer UMA das condições abaixo:\n  1. Lead pedir proposta formal, contrato ou reunião com responsável\n  2. Lead confirmar budget acima do ticket mínimo definido nas regras\n  3. Lead usar exatamente uma das keywords de escalação listadas nas regras de escalação\n  NÃO escale por simples demonstração de interesse (\"tenho interesse\", \"quero saber mais\", etc.)\n\nNa maioria das interações, NÃO use nenhuma tool — apenas responda naturalmente ao lead.\nResponda APENAS com a mensagem natural para o lead. Não use aspas nem prefixos.`;\n\nconst userMessage = webhookData.input_text ||\n  (webhookData.content_type === 'proactive' ? 'INSTRUÇÃO INTERNA: Inicie uma abordagem proativa com este lead.' :\n   webhookData.content_type === 'followup' ? 'INSTRUÇÃO INTERNA: Execute o follow-up agendado com este lead.' :\n   'Olá');\n\nreturn [{ json: { systemPrompt: fullPrompt, userMessage, webhookData } }];"
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234560008",
      "name": "Code - Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Capture start time and build Prompt lengths for token estimation\nconst buildPromptData = $('Code - Build Prompt').first().json;\n\nconst systemPrompt = buildPromptData.systemPrompt || '';\nconst userMessage = buildPromptData.userMessage || '';\n\nreturn [{\n  json: {\n    ...buildPromptData,\n    _start_time: new Date().toISOString(),\n    _prompt_char_length: systemPrompt.length + userMessage.length,\n  }\n}];"
      },
      "id": "b1c2d3e4-f5a6-7890-bcde-f01234567801",
      "name": "Code - Capture Start",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1820,
        300
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Code - Capture Start').first().json.userMessage }}",
        "options": {
          "systemMessage": "={{ $('Code - Capture Start').first().json.systemPrompt }}",
          "maxIterations": 5
        }
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234560009",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
