      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234560007",
      "name": "HTTP - Get Messages",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1400,
        300
      ],
      "alwaysOutputData": true,
      "continueOnFail": true
