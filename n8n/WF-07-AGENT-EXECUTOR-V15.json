          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "name": "atualizar_memoria",
        "description": "Registra e atualiza a memória comercial do lead: estágio atual, nível de interesse, objeções detectadas, notas da conversa. Use sempre após uma interação importante.",
        "method": "POST",
        "url": "https://fhkhamwrfwtacwydukvb.supabase.co/rest/v1/rpc/upsert_agent_lead_memory",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
