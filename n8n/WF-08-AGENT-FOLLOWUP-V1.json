      "id": "wf08-node-006",
      "name": "HTTP - Get Agent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const memory = $('Loop - Memories').first().json;\nconst agentArr = $input.all().map(i => i.json);\nconst agent = Array.isArray(agentArr[0]) ? agentArr[0][0] : agentArr[0];\n\n// Guard: agent must exist and be active\nif (!agent || !agent.id || !agent.is_active) {\n  return [{ json: { _skip: true, reason: 'agent_inactive_or_missing', memory_id: memory.id } }];\n}\n\n// Guard: skip leads in terminal stages\nconst terminalStages = ['closed_won', 'closed_lost', 'inactive', 'transferred'];\nif (terminalStages.includes(memory.stage)) {\n  return [{ json: { _skip: true, reason: 'terminal_stage_' + memory.stage, memory_id: memory.id } }];\n}\n\n// Check max followups (default 5)\nconst maxFollowups = memory.max_followups ?? (agent.escalate_rules?.max_followups) ?? 5;\nif ((memory.follow_up_count || 0) >= maxFollowups) {\n  return [{ json: { _skip: true, reason: 'max_followups_reached', memory_id: memory.id } }];\n}\n\n// Check work hours\nconst tz = agent.timezone || 'America/Sao_Paulo';\nconst now = new Date();\nconst formatter = new Intl.DateTimeFormat('en-US', {\n  timeZone: tz, hour: 'numeric', minute: 'numeric', hour12: false\n});\nconst parts = formatter.formatToParts(now);\nconst currentH = parseInt(parts.find(p => p.type === 'hour').value);\nconst currentM = parseInt(parts.find(p => p.type === 'minute').value);\nconst currentTime = currentH * 60 + currentM;\n\nconst parseTime = (t) => {\n  if (!t) return null;\n  const pts = t.toString().split(':');\n  return parseInt(pts[0]) * 60 + (parseInt(pts[1] || 0));\n};\nconst start = parseTime(agent.work_hours_start) ?? 8 * 60;\nconst end = parseTime(agent.work_hours_end) ?? 18 * 60;\n\nconst dayFormatter = new Intl.DateTimeFormat('en-US', { timeZone: tz, weekday: 'short' });\nconst day = dayFormatter.format(now);\nconst isWeekday = !['Sat', 'Sun'].includes(day);\n\nif (!(currentTime >= start && currentTime < end && isWeekday)) {\n  return [{ json: { _skip: true, reason: 'outside_work_hours', memory_id: memory.id } }];\n}\n\nreturn [{ json: { _skip: false, memory } }];"
      },
