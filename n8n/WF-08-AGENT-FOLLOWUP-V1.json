      "id": "wf08-node-002",
      "name": "HTTP - Get Pending Followups",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Flatten the response (Supabase returns JSON array directly)\nconst raw = $input.all().map(i => i.json);\nconst memories = Array.isArray(raw[0]) ? raw[0] : raw;\n\nif (!memories || memories.length === 0 || !memories[0].id) {\n  return [];\n}\n\nreturn memories.map(m => ({ json: m }));"
      },
