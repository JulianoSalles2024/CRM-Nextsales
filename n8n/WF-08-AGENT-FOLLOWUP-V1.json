    {
      "parameters": {
        "jsCode": "const validation = $('Code - Validate Agent & Hours').first().json;\nconst memory = validation.memory;\n\nconst convArr = $input.all().map(i => i.json);\nconst conv = Array.isArray(convArr[0]) ? convArr[0][0] : convArr[0];\n\nif (!conv || !conv.id) {\n  return []; // No conversation — skip silently\n}\n\n// Build the WF-07 payload\nreturn [{\n  json: {\n    conversation_id: conv.id,\n    lead_id: memory.lead_id,\n    agent_id: memory.agent_id,\n    company_id: memory.company_id,\n    input_text: '',\n    content_type: 'followup',\n    _memory_id: memory.id,\n    _followup_count: memory.follow_up_count || 0,\n    _notes: memory.notes || ''\n  }\n}];"
